<!-- Example -->


<group name="local,syslog,sshd,sudo,">

  <rule id="100200" level="8">
    <match>UFW BLOCK</match>
    <description>Custom: UFW blocked network traffic on monitored endpoint</description>
    <mitre>
      <id>T1046</id>
    </mitre>
    <group>firewall,network_scan,mitre_T1046,</group>
  </rule>

  <!-- SSH authentication failure from any source IP -->
  <rule id="100001" level="5">
    <if_sid>5716</if_sid>
    <description>Custom: SSH authentication failed on monitored endpoint</description>
    <group>authentication_failed,sshd,</group>
  </rule>

  <!-- Multiple SSH authentication failures - possible brute-force -->
  <rule id="100100" level="10" frequency="5" timeframe="120">
    <if_matched_sid>5716</if_matched_sid>
    <description>Custom: Possible SSH brute-force attack detected on monitored endpoint</description>
    <mitre>
      <id>T1110</id>
    </mitre>
    <group>authentication_failed,sshd,bruteforce,</group>
  </rule>

  <!-- Sudo command executed -->
  <rule id="100101" level="7">
    <if_sid>5402</if_sid>
    <description>Custom: Sudo command executed on monitored Linux endpoint</description>
    <mitre>
      <id>T1548.003</id>
    </mitre>
    <group>sudo,privilege_escalation,</group>
  </rule>

  <!-- Failed sudo attempt -->
  <rule id="100102" level="8">
    <if_sid>5404</if_sid>
    <description>Custom: Failed sudo attempt detected on monitored Linux endpoint</description>
    <mitre>
      <id>T1548.003</id>
    </mitre>
    <group>sudo,authentication_failed,privilege_escalation,</group>
  </rule>

</group>
